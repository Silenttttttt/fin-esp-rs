# Copy this to .env and fill in your values. Never commit .env.

WIFI_SSID=YourNetworkName
WIFI_PASS=YourPassword

# Tuya LAN key from the Tuya developer portal (exactly 16 ASCII chars)
TUYA_KEY=1234567890abcdef
# Local IP of the Tuya smart bulb
TUYA_IP=192.168.1.100

# LAN IP of the laptop running play_pause_server.py (media button feature)
LAPTOP_IP=192.168.1.x
